# DelegateAgent Orchestrator — Environment Variables
# Copy to /opt/delegate-agent/.env on the droplet and fill in real values.
#
# IMPORTANT: User-facing API keys (LLM, GitHub, etc.) are resolved
# PER-WORKSPACE from the Delegate platform's WorkspaceIntegration table.
# The keys below are infrastructure-only — used when workspace resolution
# fails or for admin operations. They are NOT used for user tasks.

# ── Delegate Platform (required) ──
DELEGATE_URL=https://delegate.ws
DELEGATE_API_KEY=<your-delegate-api-key>
DELEGATE_AGENT_TOKEN=<same-as-delegate-api-key>
# Legacy fallback (deprecated, remove in next release):
# NANOCLAW_TOKEN=<same-as-delegate-api-key>

# ── Bifrost AI Gateway (infrastructure) ──
# Bifrost runs on the same droplet. Containers route LLM calls through it
# for rate limiting, observability, and key rotation.
BIFROST_URL=http://localhost:4000

# ── LLM Provider Keys (admin fallback ONLY) ──
# These are used ONLY when per-workspace resolution fails.
# In production, each workspace's keys are resolved from Delegate DB
# via /api/agent/integrations/llm-keys at container startup.
ANTHROPIC_API_KEY=sk-bf-<admin-bifrost-virtual-key>
ANTHROPIC_BASE_URL=http://localhost:4000/anthropic
OPENAI_API_KEY=sk-proj-<admin-fallback-only>

# ── GitHub (admin fallback ONLY) ──
# Per-workspace GitHub tokens are resolved from Delegate DB via
# /api/agent/integrations/token at runtime. These are admin-only fallbacks.
GITHUB_TOKEN=ghp_<admin-fallback-only>
GH_TOKEN=ghp_<admin-fallback-only>
