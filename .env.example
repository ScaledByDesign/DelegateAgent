# DelegateAgent Orchestrator — Environment Variables
# Copy to /opt/delegate-agent/.env on the droplet and fill in values.
#
# Deploy: ./deploy/deploy.sh --init    (first time)
#         ./deploy/deploy.sh            (updates)
#         ./deploy/deploy.sh --health   (check status)

# ── Delegate Platform (required) ─────────────────────────────────────────────
# The agent connects to Delegate via these credentials.
# Get from: WebOS → Integrations → Agent Settings
DELEGATE_URL=https://delegate.ws
DELEGATE_API_KEY=
DELEGATE_AGENT_TOKEN=
# Legacy fallback (deprecated, remove in next release):
# NANOCLAW_TOKEN=

# ── Bifrost AI Gateway (infrastructure) ──────────────────────────────────────
# Bifrost runs on the same droplet. Provides rate limiting + observability.
BIFROST_URL=http://localhost:4000

# ── LLM Provider Keys ───────────────────────────────────────────────────────
# Bifrost virtual key (sk-bf-*) routes through the local gateway.
# Direct Anthropic key (sk-ant-*) bypasses Bifrost.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=http://localhost:4000/anthropic
OPENAI_API_KEY=

# ── GitHub (required for Sentry auto-fix pipeline) ──────────────────────────
# OAuth token (gho_*) or PAT (ghp_*) with repo write access.
# Per-workspace tokens are resolved from Delegate DB at runtime;
# this is the admin fallback used when workspace resolution fails.
GITHUB_TOKEN=
GH_TOKEN=
